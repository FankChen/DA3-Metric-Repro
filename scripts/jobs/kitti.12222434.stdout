# LSBATCH: User input
#!/bin/bash -l
#BSUB -J da3metric_kitti
#BSUB -P BH-000425-08-05
#BSUB -q batch_h200
#BSUB -gpu "num=1"
#BSUB -n 4
#BSUB -W 1:00
#BSUB -M 16384
#BSUB -o /home/izi2sgh/MYDATA/quanjie/liren/DA3-Metric-Repro/scripts/jobs/kitti.%J.stdout
#BSUB -e /home/izi2sgh/MYDATA/quanjie/liren/DA3-Metric-Repro/scripts/jobs/kitti.%J.stderr
#
# Reproduce DA3-Metric KITTI Eigen test results (Table 11).
# Paper:  d1=0.953, AbsRel=0.086.
# We run the full 696-image Eigen test split.

set -e
mkdir -p /home/izi2sgh/MYDATA/quanjie/liren/DA3-Metric-Repro/scripts/jobs

module purge
module load conda/25.1.1
module load cuda/12.4.0

ENV=/home/izi2sgh/MYDATA/quanjie/liren/envs/da3
export PATH="${ENV}/bin:${PATH}"
export PYTHONNOUSERSITE=1
export TORCH_CUDA_ARCH_LIST="9.0"
export HF_HOME=/home/izi2sgh/MYDATA/quanjie/liren/DA3-Metric-Repro/checkpoints/hf_cache

cd /home/izi2sgh/MYDATA/quanjie/liren/DA3-Metric-Repro

nvidia-smi | head -20
echo "------------"
which python
python --version
echo "------------"

python eval/run_kitti_eigen.py \
    --max_samples -1 \
    --device cuda \
    --process_res 504 \
    --output results/kitti_eigen_full.csv

echo "[done]"

