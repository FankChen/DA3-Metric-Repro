#BSUB -e /home/izi2sgh/MYDATA/quanjie/liren/DA3-Metric-Repro/scripts/jobs/nyu.%J.stderr
#
# Reproduce DA3-Metric NYUv2 results (Table 11).
# Paper:  d1=0.963, AbsRel=0.070.  Eval set: 654 official val images.

set -e
mkdir -p /home/izi2sgh/MYDATA/quanjie/liren/DA3-Metric-Repro/scripts/jobs

module purge
module load conda/25.1.1
module load cuda/12.4.0

ENV=/home/izi2sgh/MYDATA/quanjie/liren/envs/da3
export PATH="${ENV}/bin:${PATH}"
export PYTHONNOUSERSITE=1
export TORCH_CUDA_ARCH_LIST="9.0"

cd /home/izi2sgh/MYDATA/quanjie/liren/DA3-Metric-Repro

nvidia-smi | head -20
echo "------------"
which python
python --version
echo "------------"

python eval/run_nyuv2.py \
    --max_samples -1 \
    --device cuda \
    --process_res 504 \
    --output results/nyuv2_val.csv

echo "[done]"

