# LSBATCH: User input
#!/bin/bash -l
#BSUB -J da3metric_nyu
#BSUB -P BH-000425-08-05
#BSUB -q batch_h200
#BSUB -gpu "num=1"
#BSUB -n 4
#BSUB -W 1:00
