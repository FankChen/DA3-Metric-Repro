#
# Reproduce DA3-Metric KITTI Eigen test results (Table 11).
# Paper:  d1=0.953, AbsRel=0.086.
# We run the full 696-image Eigen test split.

set -e
mkdir -p /home/izi2sgh/MYDATA/quanjie/liren/DA3-Metric-Repro/scripts/jobs

source /etc/profile.d/modules.sh
module load conda/25.1.1
conda activate /home/izi2sgh/MYDATA/quanjie/liren/envs/da3

cd /home/izi2sgh/MYDATA/quanjie/liren/DA3-Metric-Repro

nvidia-smi | head -20
echo "------------"
which python
python --version
echo "------------"

python eval/run_kitti_eigen.py \
    --max_samples -1 \
    --device cuda \
    --process_res 504 \
    --output results/kitti_eigen_full.csv

echo "[done]"

